    "go": true,
    "docker compose": true,
    "ping": true,
    "git remote": true,
    "rsync": true,
    "scp": true,
    "tar": true,
    "openssl": true,
    "/^node -e \"const bcrypt = require\\('bcryptjs'\\); console\\.log\\(bcrypt\\.hashSync\\('123123456', 10\\)\\);\"$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
