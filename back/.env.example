APP_NAME=lista-da-vez-api
APP_ENV=development
APP_ADDR=:8080
WEB_APP_URL=http://localhost:3003

DATABASE_URL=postgres://lista_da_vez:lista_da_vez_dev@localhost:5432/lista_da_vez?sslmode=disable
DATABASE_MIN_CONNS=0
DATABASE_MAX_CONNS=10
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,http://[::1]:*

AUTH_TOKEN_SECRET=dev-secret-change-me
AUTH_TOKEN_TTL=12h
AUTH_INVITE_TTL=168h
AUTH_PASSWORD_RESET_TTL=30m
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Lista da Vez
SMTP_TLS_MODE=starttls
SMTP_INSECURE_SKIP_VERIFY=false
SMTP_TIMEOUT=10s
AUTH_BCRYPT_COST=10
AUTH_CONSULTANT_EMAIL_DOMAIN=acesso.omni.local
AUTH_CONSULTANT_DEFAULT_PASSWORD=Omni@123
