{
  "name": "lista-da-vez",
  "private": true,
  "scripts": {
    "dev": "docker compose up",
    "dev:detach": "docker compose up -d",
    "dev:build": "docker compose build",
    "dev:down": "docker compose down",
    "dev:down:volumes": "docker compose down -v",
    "dev:logs": "docker compose logs -f",
    "dev:ps": "docker compose ps",
    "dev:rebuild": "docker compose build --no-cache",
    "prod:config": "docker compose --env-file .env.production -f docker-compose.prod.yml config",
    "prod:build": "docker compose --env-file .env.production -f docker-compose.prod.yml build",
    "prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "prod:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f",
    "prod:ps": "docker compose --env-file .env.production -f docker-compose.prod.yml ps",
    "prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "prod:deploy:vps": "powershell.exe -ExecutionPolicy Bypass -File scripts\\deploy\\deploy-vps-fast.ps1",
    "prod:deploy:vps:backup": "powershell.exe -ExecutionPolicy Bypass -File scripts\\deploy\\deploy-vps-fast.ps1 -BackupDatabase",
    "dev:web": "npm --prefix web run dev",
    "dev:web:3003": "npm --prefix web run dev:3003",
    "dev:web:3001": "npm --prefix web run dev:3001",
    "dev:local": "scripts\\dev\\git-bash.cmd ./scripts/dev/up-local.sh",
    "dev:local:3003": "scripts\\dev\\git-bash.cmd ./scripts/dev/up-local.sh",
    "dev:local:3001": "scripts\\dev\\git-bash.cmd ./scripts/dev/up-local.sh",
    "dev:local:db": "scripts\\dev\\git-bash.cmd ./scripts/dev/start-postgres-local.sh",
    "dev:local:api": "scripts\\dev\\git-bash.cmd ./scripts/dev/start-api-local.sh",
    "dev:local:api:status": "scripts\\dev\\git-bash.cmd ./scripts/dev/status-api-local.sh",
    "dev:local:api:stop": "scripts\\dev\\git-bash.cmd ./scripts/dev/stop-api-local.sh",
    "build": "npm --prefix web run build",
    "generate": "npm --prefix web run generate",
    "preview": "npm --prefix web run preview"
  }
}
